{
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/daily-reminder", "schedule": "0 0 * * *" },
    { "path": "/api/cron/weekly-insight", "schedule": "0 23 * * 0" },
    { "path": "/api/events/remind", "schedule": "0 8 * * *" }
  ]
}
